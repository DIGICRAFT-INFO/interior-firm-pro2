<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 12px;
      color: #333;
      line-height: 1.5;
      padding: 40px;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 30px;
      border-bottom: 3px solid <%= brand && brand.primary_color ? brand.primary_color : '#C8922A' %>;
      padding-bottom: 20px;
    }
    .company-name {
      font-size: 22px;
      font-weight: 700;
      color: <%= brand && brand.primary_color ? brand.primary_color : '#C8922A' %>;
    }
    .company-tagline {
      font-size: 11px;
      color: #666;
      margin-top: 4px;
    }
    .doc-title {
      text-align: right;
    }
    .doc-title h1 {
      font-size: 28px;
      font-weight: 700;
      color: #333;
      letter-spacing: 1px;
    }
    .doc-title .quote-number {
      font-size: 13px;
      color: #666;
      margin-top: 4px;
    }
    .meta-section {
      display: flex;
      justify-content: space-between;
      margin-bottom: 30px;
    }
    .meta-box {
      width: 48%;
    }
    .meta-box h3 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #888;
      margin-bottom: 6px;
      border-bottom: 1px solid #eee;
      padding-bottom: 4px;
    }
    .meta-box p {
      font-size: 12px;
      margin-bottom: 3px;
    }
    .meta-box .label {
      color: #888;
      display: inline-block;
      width: 100px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 25px;
    }
    thead th {
      background: <%= brand && brand.primary_color ? brand.primary_color : '#C8922A' %>;
      color: #fff;
      padding: 10px 12px;
      text-align: left;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    thead th:last-child,
    thead th:nth-child(4),
    thead th:nth-child(5),
    thead th:nth-child(6) {
      text-align: right;
    }
    tbody td {
      padding: 9px 12px;
      border-bottom: 1px solid #eee;
      font-size: 12px;
    }
    tbody td:last-child,
    tbody td:nth-child(4),
    tbody td:nth-child(5),
    tbody td:nth-child(6) {
      text-align: right;
    }
    tbody tr:nth-child(even) {
      background: #fafafa;
    }
    .totals-section {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 30px;
    }
    .totals-table {
      width: 320px;
    }
    .totals-table table {
      margin-bottom: 0;
    }
    .totals-table td {
      padding: 7px 12px;
      border-bottom: 1px solid #eee;
    }
    .totals-table td:first-child {
      color: #666;
    }
    .totals-table td:last-child {
      text-align: right;
      font-weight: 500;
    }
    .totals-table tr.grand-total td {
      background: <%= brand && brand.primary_color ? brand.primary_color : '#C8922A' %>;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
      border-bottom: none;
    }
    .notes-section {
      margin-top: 20px;
      padding: 15px;
      background: #f9f9f9;
      border-left: 3px solid <%= brand && brand.primary_color ? brand.primary_color : '#C8922A' %>;
    }
    .notes-section h4 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #888;
      margin-bottom: 6px;
    }
    .notes-section p {
      font-size: 12px;
      color: #555;
    }
    .footer {
      margin-top: 40px;
      text-align: center;
      font-size: 10px;
      color: #999;
      border-top: 1px solid #eee;
      padding-top: 15px;
    }
    .status-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-draft { background: #f0f0f0; color: #666; }
    .status-sent { background: #e3f2fd; color: #1565c0; }
    .status-approved { background: #e8f5e9; color: #2e7d32; }
    .status-rejected { background: #ffebee; color: #c62828; }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <% if (logo_base64) { %>
      <img src="<%= logo_base64 %>" alt="Company Logo" style="height: 60px; width: auto; object-fit: contain;">
      <% } else if (brand && brand.firm_name) { %>
      <div style="font-size:20px; font-weight:700; color:<%= brand.primary_color || '#C8922A' %>;"><%= brand.firm_name %></div>
      <% } %>
      <% if (brand && brand.tagline) { %>
        <div class="company-tagline"><%= brand.tagline %></div>
      <% } %>
    </div>
    <div class="doc-title">
      <h1>QUOTATION1</h1>
      <div class="quote-number"><%= quotation.quote_number %> (v<%= quotation.version %>)</div>
    </div>
  </div>

  <div class="meta-section">
    <div class="meta-box">
      <h3>Client & Project</h3>
      <% if (quotation.project && quotation.project.client) { %>
        <p><span class="label">Client:</span> <strong><%= quotation.project.client.full_name %></strong></p>
        <% if (quotation.project.client.email) { %>
          <p><span class="label">Email:</span> <%= quotation.project.client.email %></p>
        <% } %>
        <% if (quotation.project.client.phone_number) { %>
          <p><span class="label">Phone:</span> <%= quotation.project.client.phone_number %></p>
        <% } %>
      <% } %>
      <% if (quotation.project) { %>
        <p><span class="label">Project:</span> <%= quotation.project.name %></p>
      <% } %>
    </div>
    <div class="meta-box">
      <h3>Quotation Details</h3>
      <p><span class="label">Date:</span> <%= new Date(quotation.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
      <% if (quotation.valid_until) { %>
        <p><span class="label">Valid Until:</span> <%= new Date(quotation.valid_until).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
      <% } %>
      <p><span class="label">Status:</span> <span class="status-badge status-<%= quotation.status %>"><%= quotation.status %></span></p>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Description</th>
        <th>Category</th>
        <th>Qty</th>
        <th>Unit</th>
        <th>Rate (₹)</th>
        <th>Amount (₹)</th>
      </tr>
    </thead>
    <tbody>
      <% if (items && items.length > 0) { %>
        <% items.forEach(function(item, index) { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= item.description %></td>
            <td><%= item.category || '—' %></td>
            <td style="text-align:right"><%= item.quantity %></td>
            <td style="text-align:right"><%= item.unit || '—' %></td>
            <td><%= Number(item.rate).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
            <td><%= Number(item.amount || (item.quantity * item.rate)).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr><td colspan="7" style="text-align:center; color:#999;">No items</td></tr>
      <% } %>
    </tbody>
  </table>

  <div class="totals-section">
    <div class="totals-table">
      <table>
        <tr>
          <td>Subtotal</td>
          <td>₹ <%= Number(quotation.subtotal).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
        <% if (quotation.discount_amount > 0) { %>
        <tr>
          <td>Discount (<%= quotation.discount_type === 'percentage' ? quotation.discount_value + '%' : 'Fixed' %>)</td>
          <td>- ₹ <%= Number(quotation.discount_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
        <% } %>
        <tr>
          <td>Taxable Amount</td>
          <td>₹ <%= Number(quotation.taxable_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
        <% if (quotation.cgst_amount > 0) { %>
        <tr>
          <td>CGST @ <%= quotation.cgst_rate %>%</td>
          <td>₹ <%= Number(quotation.cgst_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
        <% } %>
        <% if (quotation.sgst_amount > 0) { %>
        <tr>
          <td>SGST @ <%= quotation.sgst_rate %>%</td>
          <td>₹ <%= Number(quotation.sgst_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
        <% } %>
        <% if (quotation.igst_amount > 0) { %>
        <tr>
          <td>IGST @ <%= quotation.igst_rate %>%</td>
          <td>₹ <%= Number(quotation.igst_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
        <% } %>
        <tr class="grand-total">
          <td>Grand Total</td>
          <td>₹ <%= Number(quotation.grand_total).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
        </tr>
      </table>
    </div>
  </div>

  <% if (quotation.notes) { %>
  <div class="notes-section">
    <h4>Notes / Terms</h4>
    <p><%= quotation.notes %></p>
  </div>
  <% } %>

  <div class="footer">
    <p>This is a computer-generated document. | <%= brand && brand.company_name ? brand.company_name : 'Interior Firm' %></p>
  </div>
</body>
</html>
