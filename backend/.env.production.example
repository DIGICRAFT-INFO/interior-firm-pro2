# Copy this file to .env on your Hostinger server and fill in real values.
# DO NOT commit this file with real secrets.

NODE_ENV=production
PORT=5000

# Your Hostinger backend public URL (used in email links)
BACKEND_URL=https://api.yourdomain.com

# MongoDB Atlas connection string (same as dev, or a separate production cluster)
MONGODB_URI=mongodb+srv://...

# STRONG random secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_TO_STRONG_RANDOM_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_TO_DIFFERENT_STRONG_RANDOM_64_CHAR_HEX

# WhatsApp Business API
WA_PHONE_NUMBER_ID=your_meta_phone_id
WA_ACCESS_TOKEN=your_meta_permanent_token
WA_VERIFY_TOKEN=your_custom_verify_token

# Gmail App Password (Settings > Security > App passwords)
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# Firm name shown in emails and PDFs
FIRM_NAME=Your Interior Firm Name

# Your deployed frontend URL — used for CORS
FRONTEND_URL=https://yourdomain.com

# Puppeteer — on Hostinger you may need @sparticuz/chromium or system chrome
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
